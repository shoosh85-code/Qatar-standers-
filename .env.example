# QatarSpec Pro — Environment Variables
# Copy to .env.local for development
# Set in Vercel Dashboard → Settings → Environment Variables for production

# ── Gemini AI (Required for Smart Search) ──
# Get from: https://aistudio.google.com/app/apikey
GEMINI_KEY=your_gemini_api_key_here

# ── Supabase (Required for QCS Database Search) ──
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Secret (Required for Pro Auth) ──
# Generate: openssl rand -hex 32
JWT_SECRET=your_random_secret_at_least_32_chars_here

# ── Pro Promo Codes (comma-separated, no spaces) ──
# Used by /api/verify-pro.js
PROMO_CODES=QATAR2026PRO,EARLYBIRD2026,QATARENG2026,PROCODE2026

# ── App URL (CORS origin) ──
APP_URL=https://qatar-standers.vercel.app
