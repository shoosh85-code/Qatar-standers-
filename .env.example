
# ═══════════════════════════════════════════════════════
# QatarSpec Pro — Vercel Environment Variables (v3.0.0)
# نسخ هذا الملف إلى .env.local وتعبئة القيم الحقيقية
# ═══════════════════════════════════════════════════════

# AI — Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — استخدم هذه الأسماء دائماً (Vercel compatible)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Upstash Redis — Rate Limiting (مشترك بين كل Edge instances)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# TAP Payments
TAP_SECRET_KEY=your_tap_secret_key
TAP_WEBHOOK_SECRET=your_tap_webhook_secret

# Security — أنشئ بـ: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters
ADMIN_SECRET=your_admin_secret_minimum_32_characters

# App URL
APP_URL=https://qatar-standers.vercel.app
