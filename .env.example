# QatarSpec Pro — Environment Variables
# Copy to .env.local for development
# Set in Vercel Dashboard → Settings → Environment Variables for production

# ── Upstash Redis (Required for Rate Limiting across instances) ──
# Get from: https://console.upstash.com → Create Database → REST API
# خطوات: console.upstash.com → New Database → اسم: qatar-spec-rl → Region: eu-west-1 → Create
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
# Note: @vercel/kv انتهى — استخدم @upstash/redis مباشرة

# ── TAP Payments (Required for Pro subscription checkout) ──
# Get from: https://businesses.tap.company → Developers → API Keys
TAP_SECRET_KEY=your_tap_secret_key_here
# Get from: https://businesses.tap.company → Webhooks → Secret
TAP_WEBHOOK_SECRET=your_tap_webhook_secret_here

# ── Gemini AI (Required for Smart Search) ──
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (Required for QCS Database Search) ──
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT Secret (Required for Pro Auth) ──
# Generate: openssl rand -hex 32
JWT_SECRET=your_random_secret_at_least_32_chars_here

# ── Pro Promo Codes (comma-separated, no spaces) ──
# Used by /api/verify-pro.js
PROMO_CODES=QATAR2026PRO,EARLYBIRD2026,QATARENG2026,PROCODE2026

# ── App URL (CORS origin) ──
APP_URL=https://qatar-standers.vercel.app
