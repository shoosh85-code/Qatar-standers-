# QatarSpec Pro — Environment Variables Example
# انسخ هذا الملف إلى .env.local وأضف القيم الحقيقية
# لا ترفع .env.local على GitHub أبداً

# ── Gemini AI (required) ──
GEMINI_API_KEY=your_gemini_key_here

# ── Supabase (required) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Stripe Payment (optional — for Pro subscription) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App Config ──
APP_ENV=production
RATE_LIMIT_ENABLED=true

# ── 3D Scanning ──
KIRI_API_KEY=your_kiri_engine_key_here
KIRI_API_ENDPOINT=https://api.kiri.art/v1
# SCAN_BACKEND: gemini-fallback | kiri | colmap-gsplat
SCAN_BACKEND=gemini-fallback
POLYCAM_API_KEY=your_polycam_key_here

# ── COLMAP + Gaussian Splat Backend (Railway / Fly.io) ──
# SCAN_BACKEND=colmap-gsplat يتطلب هذه المتغيرات
BACKEND_URL=https://your-backend.fly.dev
BACKEND_SECRET=random_secret_for_auth

# ── Cloudflare R2 Storage (مجاني حتى 10GB) ──
CLOUDFLARE_R2_BUCKET=qatarspec-scans
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# ── Redis (Upstash) — للـ distributed rate limiting ──
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Security ──
JWT_SECRET=random_32_char_string_here
TAP_SECRET_KEY=your_tap_key_here
