{
  "version": 2,
  "outputDirectory": ".",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/360-tour.html",
      "destination": "/360-tour.html"
    },
    {
      "source": "/3d-analyzer.html",
      "destination": "/3d-analyzer.html"
    },
    {
      "source": "/3d-scanner.html",
      "destination": "/3d-scanner.html"
    },
    {
      "source": "/3d-test.html",
      "destination": "/3d-test.html"
    },
    {
      "source": "/404.html",
      "destination": "/404.html"
    },
    {
      "source": "/500.html",
      "destination": "/500.html"
    },
    {
      "source": "/admin-db-setup.html",
      "destination": "/admin-db-setup.html"
    },
    {
      "source": "/admin-embeddings.html",
      "destination": "/admin-embeddings.html"
    },
    {
      "source": "/admin-project-hub-setup.html",
      "destination": "/admin-project-hub-setup.html"
    },
    {
      "source": "/admin-qcs-upload.html",
      "destination": "/admin-qcs-upload.html"
    },
    {
      "source": "/analyzer-v2.html",
      "destination": "/analyzer-v2.html"
    },
    {
      "source": "/analyzer.html",
      "destination": "/analyzer.html"
    },
    {
      "source": "/blueprint.html",
      "destination": "/blueprint.html"
    },
    {
      "source": "/boq-pricer.html",
      "destination": "/boq-pricer.html"
    },
    {
      "source": "/dpr-generator.html",
      "destination": "/dpr-generator.html"
    },
    {
      "source": "/embedding-runner.html",
      "destination": "/embedding-runner.html"
    },
    {
      "source": "/execution-hub.html",
      "destination": "/execution-hub.html"
    },
    {
      "source": "/grading-curve.html",
      "destination": "/grading-curve.html"
    },
    {
      "source": "/health.html",
      "destination": "/health.html"
    },
    {
      "source": "/ifc-viewer.html",
      "destination": "/ifc-viewer.html"
    },
    {
      "source": "/index-NEW.html",
      "destination": "/index-NEW.html"
    },
    {
      "source": "/landing.html",
      "destination": "/landing.html"
    },
    {
      "source": "/login.html",
      "destination": "/login.html"
    },
    {
      "source": "/method-statement.html",
      "destination": "/method-statement.html"
    },
    {
      "source": "/mos-itp.html",
      "destination": "/mos-itp.html"
    },
    {
      "source": "/ncr-generator.html",
      "destination": "/ncr-generator.html"
    },
    {
      "source": "/offline.html",
      "destination": "/offline.html"
    },
    {
      "source": "/project-detail.html",
      "destination": "/project-detail.html"
    },
    {
      "source": "/projects.html",
      "destination": "/projects.html"
    },
    {
      "source": "/scanner.html",
      "destination": "/scanner.html"
    },
    {
      "source": "/subscribe.html",
      "destination": "/subscribe.html"
    },
    {
      "source": "/success.html",
      "destination": "/success.html"
    },
    {
      "source": "/test-api.html",
      "destination": "/test-api.html"
    },
    {
      "source": "/test-gemini.html",
      "destination": "/test-gemini.html"
    },
    {
      "source": "/tools.html",
      "destination": "/tools.html"
    },
    {
      "source": "/translation-runner.html",
      "destination": "/translation-runner.html"
    },
    {
      "source": "/visual-hub.html",
      "destination": "/visual-hub.html"
    },
    {
      "source": "/work-acceptance.html",
      "destination": "/work-acceptance.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/admin-embeddings.html",
      "destination": "/",
      "statusCode": 302
    },
    {
      "source": "/translation-runner.html",
      "destination": "/",
      "statusCode": 302
    }
  ],
  "functions": {
    "api/ai-proxy.js": {
      "maxDuration": 60
    },
    "api/qcs-search.js": {
      "maxDuration": 30
    },
    "api/chatbot.js": {
      "maxDuration": 60
    },
    "api/project-hub.js": {
      "maxDuration": 30
    },
    "api/tap.js": {
      "maxDuration": 30
    },
    "api/export-pdf.js": {
      "maxDuration": 60
    },
    "api/auth.js": {
      "maxDuration": 30
    },
    "api/scanner.js": {
      "maxDuration": 60
    },
    "api/hub-extended.js": {
      "maxDuration": 60
    },
    "api/blueprint.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/js/(.*)\\.min\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/css/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "off"
        },
        {
          "key": "X-Download-Options",
          "value": "noopen"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), autoplay=(), encrypted-media=(), picture-in-picture=(), display-capture=(), fullscreen=(self), clipboard-read=(), clipboard-write=(self), bluetooth=(), serial=(), hid=(), idle-detection=(), screen-wake-lock=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        },
        {
          "key": "Origin-Agent-Cluster",
          "value": "?1"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://docs.opencv.org https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.googletagmanager.com https://www.google-analytics.com https://plausible.io https://*.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://generativelanguage.googleapis.com https://docs.opencv.org https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.google-analytics.com https://region1.google-analytics.com https://*.supabase.co https://*.upstash.io https://plausible.io https://app.posthog.com https://*.i.posthog.com https://*.ingest.sentry.io; img-src 'self' data: blob: https:; media-src 'self' blob:; worker-src 'self' blob: https://cdnjs.cloudflare.com; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; manifest-src 'self' blob:"
        },
        {
          "key": "Vary",
          "value": "Origin"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/hub-extended?resource=embed-cron",
      "schedule": "0 2 * * *"
    }
  ],
  "cleanUrls": false
}