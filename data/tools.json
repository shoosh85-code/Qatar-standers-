{
  "calculator": {
    "title":"🧮 حاسبة المواصفات","cat":"tools",
    "content":"<div style='display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;'><button id='main-tab-roads' onclick='switchMainCat(\"roads\",this)' style='background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:6px 14px;font-size:12px;color:var(--gold2);font-weight:700;cursor:pointer;font-family:Tajawal,sans-serif;'>🛣️ طرق</button><button id='main-tab-utilities' onclick='switchMainCat(\"utilities\",this)' style='background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:6px 14px;font-size:12px;color:var(--text2);cursor:pointer;font-family:Tajawal,sans-serif;'>🔧 مرافق</button><button id='main-tab-structural' onclick='switchMainCat(\"structural\",this)' style='background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:6px 14px;font-size:12px;color:var(--text2);cursor:pointer;font-family:Tajawal,sans-serif;'>🏗️ إنشاء</button><button id='main-tab-geotech_calc' onclick='switchMainCat(\"geotech_calc\",this)' style='background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:6px 14px;font-size:12px;color:var(--text2);cursor:pointer;font-family:Tajawal,sans-serif;'>🔬 جسات</button></div><div id='cat-roads'></div><div id='cat-utilities' style='display:none;'></div><div id='cat-structural' style='display:none;'></div><div id='cat-geotech_calc' style='display:none;'></div>"
  },
  "doc_analyzer": {
    "title":"📁 محلل الوثائق","cat":"tools",
    "content":"<div class='lang-content-ar'><div class='qcs-ref-badge'>📌 AI Document Analyzer — QCS 2024</div><h3>تحليل وثائق المشروع</h3><p style='font-size:12px;color:var(--text2);margin-bottom:14px;'>ارفع مواصفات المشروع أو جداول الكميات وسيحلل الذكاء الاصطناعي المتطلبات الرئيسية</p><div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;'><div style='background:var(--dark4);border:2px dashed rgba(201,168,76,.2);border-radius:10px;padding:14px;text-align:center;cursor:pointer;' onclick='document.getElementById(\"spec-upload\").click()'><div style='font-size:20px;margin-bottom:6px;'>📋</div><div style='font-size:12px;color:var(--text2);'>المواصفات الخاصة</div><div style='font-size:10px;color:var(--text3);'>Project Specs PDF</div><input type='file' id='spec-upload' style='display:none;' accept='.pdf' onchange='handleDocUpload(this,\"specs\")'></div><div style='background:var(--dark4);border:2px dashed rgba(201,168,76,.2);border-radius:10px;padding:14px;text-align:center;cursor:pointer;' onclick='document.getElementById(\"boq-upload\").click()'><div style='font-size:20px;margin-bottom:6px;'>📊</div><div style='font-size:12px;color:var(--text2);'>جدول الكميات</div><div style='font-size:10px;color:var(--text3);'>BOQ Excel/PDF</div><input type='file' id='boq-upload' style='display:none;' accept='.pdf,.xlsx' onchange='handleDocUpload(this,\"boq\")'></div></div><div id='doc-files-list' style='margin-bottom:12px;'></div><div id='doc-analysis-panel' style='display:none;'><div style='margin-bottom:10px;'><label style='font-size:12px;color:var(--text2);'>نوع المشروع<br><select id='doc-project-type' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:6px;padding:8px;font-family:Tajawal,sans-serif;color:var(--text1);margin-top:4px;'><option value=\"roads\">طرق وأرصفة</option><option value=\"utilities\">مرافق وشبكات</option><option value=\"building\">مباني وإنشاء</option><option value=\"mixed\">مختلط</option></select></label></div><button onclick='runDocAnalysis()' style='background:linear-gradient(135deg,var(--maroon),var(--maroon2));border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:10px;color:var(--gold2);font-family:Tajawal,sans-serif;font-size:14px;font-weight:700;cursor:pointer;width:100%;margin-bottom:12px;'>🤖 تحليل بالذكاء الاصطناعي</button><div id='doc-ai-result'></div></div></div>"
  }
}
