{
  "ncr_log_template": {
    "title": "📋 نموذج NCR — عدم المطابقة",
    "cat": "ashghal",
    "pro_only": true,
    "content": "<div class='qcs-ref-badge'>📌 Ashghal QA/QC Procedure | Pro Feature</div><h3>Non-Conformance Report (NCR)</h3><div class='form-template'><table class='form-table'><tr><td style='width:120px;font-size:12px;color:var(--text2);'>Project:</td><td><input type='text' id='ncr_project' placeholder='اسم المشروع' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'></td><td style='width:80px;font-size:12px;color:var(--text2);'>NCR No:</td><td><input type='text' id='ncr_no' placeholder='NCR-001' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'></td></tr><tr><td style='font-size:12px;color:var(--text2);vertical-align:top;padding-top:8px;'>Description:</td><td colspan='3'><textarea id='ncr_desc' rows='3' placeholder='وصف المشكلة / عدم المطابقة' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);resize:vertical;'></textarea></td></tr><tr><td style='font-size:12px;color:var(--text2);'>QCS Reference:</td><td><input type='text' id='ncr_ref' placeholder='QCS 2024 — Part X Cl.X.X' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'></td><td style='font-size:12px;color:var(--text2);'>Date:</td><td><input type='date' id='ncr_date' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'></td></tr><tr><td style='font-size:12px;color:var(--text2);vertical-align:top;padding-top:8px;'>Corrective Action:</td><td colspan='3'><textarea id='ncr_action' rows='3' placeholder='الإجراء التصحيحي المقترح' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);resize:vertical;'></textarea></td></tr><tr><td style='font-size:12px;color:var(--text2);'>Inspector:</td><td><input type='text' id='ncr_inspector' placeholder='اسم المفتش' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'></td><td style='font-size:12px;color:var(--text2);'>Status:</td><td><select id='ncr_status' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);'><option>Open</option><option>Under Review</option><option>Closed</option><option>Rejected</option></select></td></tr></table><div style='margin-top:12px;display:flex;gap:8px;'><button onclick='saveNCR()' style='background:linear-gradient(135deg,var(--maroon),var(--maroon2));border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:8px 18px;color:var(--gold2);font-family:Tajawal,sans-serif;font-size:13px;font-weight:700;cursor:pointer;'>💾 حفظ NCR</button><button onclick='exportNCRPDF()' style='background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:8px 18px;color:var(--text2);font-family:Tajawal,sans-serif;font-size:13px;cursor:pointer;'>📄 تصدير PDF</button></div></div><script>function saveNCR(){var data={project:document.getElementById('ncr_project').value,no:document.getElementById('ncr_no').value,desc:document.getElementById('ncr_desc').value,ref:document.getElementById('ncr_ref').value,date:document.getElementById('ncr_date').value,action:document.getElementById('ncr_action').value,inspector:document.getElementById('ncr_inspector').value,status:document.getElementById('ncr_status').value};var list=JSON.parse(localStorage.getItem('qsp_ncr_list')||'[]');list.push({...data,id:Date.now()});localStorage.setItem('qsp_ncr_list',JSON.stringify(list));if(typeof showToast==='function')showToast('✅ تم حفظ NCR — '+data.no);}function exportNCRPDF(){var n=document.getElementById('ncr_no').value||'NCR';var p=document.getElementById('ncr_project').value||'Project';var w=window.open();w.document.write('<html dir=rtl><head><style>body{font-family:Arial,sans-serif;padding:20px;direction:rtl;}h2{color:#7a1515;}table{width:100%;border-collapse:collapse;}td{padding:8px;border:1px solid #ccc;font-size:12px;}</style></head><body><h2>Non-Conformance Report</h2><table><tr><td>Project</td><td>'+p+'</td><td>NCR No</td><td>'+n+'</td></tr><tr><td>Description</td><td colspan=3>'+document.getElementById('ncr_desc').value+'</td></tr><tr><td>QCS Reference</td><td>'+document.getElementById('ncr_ref').value+'</td><td>Date</td><td>'+document.getElementById('ncr_date').value+'</td></tr><tr><td>Corrective Action</td><td colspan=3>'+document.getElementById('ncr_action').value+'</td></tr><tr><td>Inspector</td><td>'+document.getElementById('ncr_inspector').value+'</td><td>Status</td><td>'+document.getElementById('ncr_status').value+'</td></tr></table><p style=margin-top:40px;>Signature: _____________________ Date: _____________</p></body></html>');w.print();}</script>"
  },
  "ashghal_forms": {
    "title": "📝 نماذج Ashghal الرسمية",
    "cat": "ashghal",
    "pro_only": true,
    "content": "<div class='qcs-ref-badge'>📌 Ashghal PWA | Official QA Forms</div><h3>النماذج الرسمية المتاحة</h3><div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px;'><div onclick=\"openDetail('ncr_log_template')\" style='background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;transition:.2s;' onmouseover='this.style.borderColor=\"rgba(201,168,76,.4)\"' onmouseout='this.style.borderColor=\"rgba(201,168,76,.12)\"'><div style='font-size:20px;margin-bottom:8px;'>📋</div><div style='font-size:13px;font-weight:700;color:var(--text1);'>NCR Form</div><div style='font-size:11px;color:var(--text3);'>Non-Conformance Report</div></div><div style='background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;'><div style='font-size:20px;margin-bottom:8px;'>📄</div><div style='font-size:13px;font-weight:700;color:var(--text1);'>RFI Form</div><div style='font-size:11px;color:var(--text3);'>Request For Information</div></div><div style='background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;'><div style='font-size:20px;margin-bottom:8px;'>📝</div><div style='font-size:13px;font-weight:700;color:var(--text1);'>Method Statement</div><div style='font-size:11px;color:var(--text3);'>Approval Form</div></div><div style='background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;'><div style='font-size:20px;margin-bottom:8px;'>🔍</div><div style='font-size:13px;font-weight:700;color:var(--text1);'>Inspection Request</div><div style='font-size:11px;color:var(--text3);'>ITP Notification</div></div></div>"
  },
  "daily_report_generator": {
    "title": "📅 Daily Report Generator",
    "cat": "ashghal",
    "pro_only": true,
    "content": "<div class='qcs-ref-badge'>📌 Daily Construction Report Template</div><h3>تقرير اليومي</h3><div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0;'><label style='font-size:12px;color:var(--text2);'>التاريخ<br><input type='date' id='rep_date' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Tajawal,sans-serif;color:var(--text1);font-size:12px;'></label><label style='font-size:12px;color:var(--text2);'>حالة الطقس<br><select id='rep_weather' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Tajawal,sans-serif;color:var(--text1);font-size:12px;'><option>صافي / Clear</option><option>غيوم جزئي</option><option>رياح / Windy</option><option>غبار / Dusty</option><option>أمطار / Rain</option><option>حار جداً ≥45°C</option></select></label></div><label style='font-size:12px;color:var(--text2);display:block;margin-bottom:8px;'>الأنشطة المنجزة<br><textarea id='rep_activities' rows='3' placeholder='صف الأعمال المنجزة اليوم...' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);resize:vertical;'></textarea></label><div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px;'><label style='font-size:12px;color:var(--text2);'>العمالة (عدد)<br><input type='number' id='rep_mp' placeholder='50' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Tajawal,sans-serif;color:var(--text1);font-size:12px;'></label><label style='font-size:12px;color:var(--text2);'>المعدات<br><input type='text' id='rep_equip' placeholder='Paver, Roller, etc.' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;font-family:Tajawal,sans-serif;color:var(--text1);font-size:12px;'></label></div><label style='font-size:12px;color:var(--text2);display:block;margin-bottom:10px;'>ملاحظات / مشاكل<br><textarea id='rep_issues' rows='2' placeholder='أي مشاكل أو NCRs أو ملاحظات...' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-family:Tajawal,sans-serif;font-size:12px;color:var(--text1);resize:vertical;'></textarea></label><button onclick='generateDailyReport()' style='background:linear-gradient(135deg,var(--maroon),var(--maroon2));border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:10px 24px;color:var(--gold2);font-family:Tajawal,sans-serif;font-size:14px;font-weight:700;cursor:pointer;width:100%;'>📄 توليد التقرير</button><script>function generateDailyReport(){var data={date:document.getElementById('rep_date').value||new Date().toLocaleDateString('ar'),weather:document.getElementById('rep_weather').value,activities:document.getElementById('rep_activities').value,mp:document.getElementById('rep_mp').value,equip:document.getElementById('rep_equip').value,issues:document.getElementById('rep_issues').value};var w=window.open();w.document.write('<html dir=rtl><head><style>body{font-family:Arial,sans-serif;padding:20px;direction:rtl;font-size:13px;}h2{color:#7a1515;border-bottom:2px solid #7a1515;padding-bottom:8px;}table{width:100%;border-collapse:collapse;margin-top:12px;}th{background:#7a1515;color:#fff;padding:8px;text-align:right;}td{padding:8px;border:1px solid #ccc;}</style></head><body><h2>Daily Construction Report</h2><p>التاريخ: '+data.date+' | QatarSpec Pro</p><table><tr><th>البيان</th><th>التفاصيل</th></tr><tr><td>حالة الطقس</td><td>'+data.weather+'</td></tr><tr><td>الأنشطة المنجزة</td><td>'+data.activities+'</td></tr><tr><td>العمالة</td><td>'+data.mp+' عامل</td></tr><tr><td>المعدات</td><td>'+data.equip+'</td></tr><tr><td>ملاحظات / مشاكل</td><td>'+data.issues+'</td></tr></table><div style=margin-top:40px;display:flex;justify-content:space-between;><div>توقيع المهندس: _____________</div><div>التاريخ: _____________</div></div></body></html>');w.print();}</script>"
  },
  "rfi_template": {
    "title": "📝 نموذج RFI — طلب المعلومات",
    "cat": "ashghal",
    "pro_only": true,
    "content": "<div class='lang-content-ar'><div class='qcs-ref-badge'>📌 نماذج Ashghal الرسمية | Pro Only</div><h3>Request for Information (RFI)</h3><div class='form-template'><table class='form-table'><tr><td style='width:120px;font-weight:600'>Project:</td><td><input type='text' id='rfi_project' placeholder='اسم المشروع' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal'></td><td style='width:80px;font-weight:600'>RFI No:</td><td><input type='text' id='rfi_no' placeholder='RFI-001' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal'></td></tr><tr><td colspan='4'><label style='font-size:12px;color:var(--text2)'>Subject / الموضوع:</label><input type='text' id='rfi_subject' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal;margin-top:4px'></td></tr><tr><td colspan='4'><label style='font-size:12px;color:var(--text2)'>Question / السؤال:</label><textarea id='rfi_question' rows='4' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal;margin-top:4px'></textarea></td></tr><tr><td colspan='4'><label style='font-size:12px;color:var(--text2)'>Drawing/Spec Reference:</label><input type='text' id='rfi_ref' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal;margin-top:4px'></td></tr><tr><td style='font-weight:600'>Date Required:</td><td><input type='date' id='rfi_date' style='background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text)'></td><td style='font-weight:600'>Submitted by:</td><td><input type='text' id='rfi_by' style='width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:4px;padding:6px;color:var(--text);font-family:Tajawal'></td></tr></table><div style='margin-top:12px;display:flex;gap:8px'><button onclick='saveRFI()' style='background:linear-gradient(135deg,var(--maroon),var(--maroon2));border:1px solid rgba(201,168,76,.3);border-radius:8px;padding:8px 16px;color:var(--gold2);font-family:Tajawal;font-size:13px;font-weight:700;cursor:pointer'>💾 حفظ RFI</button><button onclick='printRFI()' style='background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:8px 16px;color:var(--text2);font-family:Tajawal;font-size:13px;cursor:pointer'>📄 طباعة</button></div></div><script>function saveRFI(){var rfi={no:document.getElementById(\"rfi_no\").value,project:document.getElementById(\"rfi_project\").value,subject:document.getElementById(\"rfi_subject\").value,question:document.getElementById(\"rfi_question\").value,ref:document.getElementById(\"rfi_ref\").value,date:document.getElementById(\"rfi_date\").value,by:document.getElementById(\"rfi_by\").value,ts:Date.now()};var all=JSON.parse(localStorage.getItem(\"qsp_rfis\")||\"[]\");all.unshift(rfi);localStorage.setItem(\"qsp_rfis\",JSON.stringify(all));showToast(\"✅ تم حفظ RFI-\"+rfi.no);}function printRFI(){window.print();}</script></div>"
  },
  "ai_site_inspector": {
    "title": "📸 AI Site Inspector — فحص الموقع الذكي",
    "cat": "ashghal",
    "pro_only": true,
    "content": "<div class='lang-content-ar'><div class='qcs-ref-badge'>📌 AI Site Inspector | QCS 2024 | Pro Only</div><h3>ارفع صورة من الموقع — يحدد AI المخالفات</h3><div style='border:2px dashed rgba(201,168,76,.3);border-radius:12px;padding:24px;text-align:center;margin:12px 0;cursor:pointer' onclick='document.getElementById(\"sitePhotoInput\").click()'><div style='font-size:32px;margin-bottom:8px'>📸</div><div style='font-size:14px;color:var(--text2)'>اضغط لرفع صورة من الموقع</div><div style='font-size:11px;color:var(--text3);margin-top:4px'>JPEG/PNG — حجم أقصى 5MB</div><input type='file' id='sitePhotoInput' accept='image/*' style='display:none' onchange='runSiteInspection(this)'></div><div id='inspectionPreview' style='display:none;margin:12px 0'><img id='sitePhotoPreview' style='max-width:100%;border-radius:8px;border:1px solid var(--border)'></div><div id='inspectionLoading' style='display:none;text-align:center;padding:16px'><div class='spinner'></div><div style='font-size:13px;color:var(--text2);margin-top:8px'>AI يحلل الصورة وفق QCS 2024...</div></div><div id='inspectionResult' style='display:none'></div><script>function runSiteInspection(input){var file=input.files[0];if(!file)return;if(file.size>5*1024*1024){showToast(\"⚠️ الصورة أكبر من 5MB\");return;}var reader=new FileReader();reader.onload=function(e){var b64=e.target.result.split(\",\")[1];document.getElementById(\"sitePhotoPreview\").src=e.target.result;document.getElementById(\"inspectionPreview\").style.display=\"block\";document.getElementById(\"inspectionLoading\").style.display=\"block\";document.getElementById(\"inspectionResult\").style.display=\"none\";fetch(\"/api/search\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\",\"X-Pro-Token\":localStorage.getItem(\"qsp_pro_token\")||\"?\"},body:JSON.stringify({query:\"فحص صورة الموقع بحثاً عن مخالفات QCS 2024\",imageBase64:b64,messages:[{role:\"user\",content:[{type:\"image_url\",image_url:{url:e.target.result}},{type:\"text\",text:\"أنت مفتش جودة خبير في QCS 2024 Qatar. فحص هذه الصورة من موقع البناء وحدد:\\n1. أي مخالفات أو عدم مطابقة مع QCS 2024\\n2. البند المرجعي الدقيق من QCS\\n3. الإجراء التصحيحي المطلوب\\n4. درجة الخطورة: منخفضة / متوسطة / عالية\\nالرد بالعربية.\"}]}]})}).then(function(r){return r.json();}).then(function(data){document.getElementById(\"inspectionLoading\").style.display=\"none\";var result=data.answer||\"تعذر تحليل الصورة\";var el=document.getElementById(\"inspectionResult\");el.style.display=\"block\";el.innerHTML=\"<div style='background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:16px'><div style='color:var(--gold);font-weight:700;margin-bottom:8px'>🤖 نتيجة الفحص الذكي</div><div style='font-size:13px;color:var(--text2);line-height:1.8'>\"+result.replace(/\\n/g,\"<br>\")+\"</div></div>\";}).catch(function(){document.getElementById(\"inspectionLoading\").style.display=\"none\";showToast(\"❌ فشل الاتصال — تحقق من الاتصال\");});};reader.readAsDataURL(file);}</script></div>"
  }
}